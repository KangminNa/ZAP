# ── ZAP 프로덕션 환경 변수 ─────────────────────────────────
# docker-compose.yml이 이 파일을 읽음
# 사용법: cp .env.example .env → 값 수정 → docker compose up -d

# ── 포트 (Nginx Proxy Manager에서 이 포트로 연결) ──────────
CLIENT_PORT=3080
SERVER_PORT=3000

# ❗ 반드시 교체 (openssl rand -hex 32)
AUTH_SECRET=CHANGE_ME_TO_RANDOM_64_HEX_STRING

# ❗ 반드시 교체
MINIO_ROOT_USER=zap_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# 브라우저가 presigned URL로 MinIO에 직접 접근하는 주소
# Nginx Proxy Manager에서 MinIO도 프록시하는 경우:
#   MINIO_PUBLIC_ENDPOINT=files.your-domain.com
#   MINIO_PUBLIC_PORT=443
#   MINIO_PUBLIC_USE_SSL=true
MINIO_PUBLIC_ENDPOINT=minio
MINIO_PUBLIC_PORT=9000
MINIO_PUBLIC_USE_SSL=false

# CORS (프론트 도메인)
CORS_ORIGIN=https://your-domain.com

# MinIO 콘솔 (운영 시 제거 권장)
MINIO_CONSOLE_PORT=9001
