{
  "name": "zap",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.7.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter=./apps/* dev",
    "dev:server": "pnpm --filter @zap/server dev",
    "dev:client": "pnpm --filter @zap/client dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "infra:up": "docker compose -f infra/docker-compose.yml --env-file infra/.env up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
