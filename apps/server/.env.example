NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# Valkey
VALKEY_URL=redis://localhost:6379

# MinIO — 서버 ↔ MinIO 내부 연결
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=zap_admin
MINIO_SECRET_KEY=zap_secret_change_me
MINIO_BUCKET=zap-sessions

# MinIO — 브라우저가 접근할 공개 주소 (presigned URL 발급에 사용)
# 로컬 개발 중엔 localhost, 배포 시에는 공개 도메인
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_PORT=9000
MINIO_PUBLIC_USE_SSL=false
