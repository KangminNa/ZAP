# ─────────────────────────────────────────────────────────────
# @zap/server — 환경 변수 템플릿
#
# 사용법:
#   로컬 개발:  cp .env.example .env
#   배포:       cp .env.example .env.production  (또는 오케스트레이터 주입)
#
# .env, .env.production 등은 gitignore 되어 커밋되지 않습니다.
# ─────────────────────────────────────────────────────────────

# ── 런타임 ─────────────────────────────────────────────────────
NODE_ENV=development              # development | production | test
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info                    # fatal | error | warn | info | debug | trace

# 리버스 프록시(nginx/ALB/Cloudflare) 뒤에 있으면 true.
# Fastify가 X-Forwarded-* 헤더를 신뢰하여 req.ip를 복원합니다.
TRUST_PROXY=false

# ── CORS ──────────────────────────────────────────────────────
# 로컬: http://localhost:5173
# 배포: https://app.your-domain.com (프론트 공개 도메인)
CORS_ORIGIN=http://localhost:5173

# ── Valkey (Redis 호환) ────────────────────────────────────────
# 로컬: redis://localhost:6379
# 배포: redis://user:password@host:6379/0
VALKEY_URL=redis://localhost:6379

# ── MinIO 내부 연결 (서버 → MinIO) ─────────────────────────────
# 로컬:   localhost:9000
# 배포:   도커 네트워크 내부 호스트명 또는 내부 DNS
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false

# ❗ 배포 시 반드시 강력한 값으로 교체 (필수, 기본값 없음)
MINIO_ACCESS_KEY=zap_admin
MINIO_SECRET_KEY=zap_secret_change_me
MINIO_BUCKET=zap-sessions

# ── MinIO 공개 연결 (브라우저 → MinIO, presigned URL 발급용) ────
# 브라우저가 presigned URL로 직접 PUT/GET 하는 주소.
# 로컬:   localhost:9000 (내부와 동일)
# 배포:   files.your-domain.com:443 (리버스 프록시 경유)
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_PORT=9000
MINIO_PUBLIC_USE_SSL=false

# ── 인증 ────────────────────────────────────────────────────
# ❗ 배포 시 반드시 강력한 랜덤 값으로 교체 (최소 32자, 기본값 없음)
# 생성 예: openssl rand -hex 32
AUTH_SECRET=dev-only-secret-change-me-in-production-min32chars
AUTH_TOKEN_TTL_HOURS=24
